{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Proactive infrastructure updates for Docker images, CI/CD actions, and Helm charts to ensure timely security patches",
  "packageRules": [
    {
      "description": "Update Docker images weekly on Mondays before 9am",
      "matchCategories": ["docker"],
      "matchUpdateTypes": ["patch", "minor", "major"],
      "schedule": ["* 0-8 * * 1"],
      "labels": ["🐳 Docker"],
      "minimumReleaseAge": "1 day"
    },
    {
      "description": "Update CI/CD actions weekly on Mondays before 9am",
      "matchCategories": ["ci"],
      "matchUpdateTypes": ["patch", "minor"],
      "schedule": ["* 0-8 * * 1"],
      "labels": ["⚡ CI/CD"],
      "minimumReleaseAge": "1 day"
    },
    {
      "description": "Update Helm charts weekly on Mondays before 9am",
      "matchCategories": ["helm"],
      "matchUpdateTypes": ["patch", "minor"],
      "schedule": ["* 0-8 * * 1"],
      "labels": ["⎈ Helm"],
      "minimumReleaseAge": "1 day"
    }
  ]
}
